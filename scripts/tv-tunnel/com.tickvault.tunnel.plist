<?xml version="1.0" encoding="UTF-8"?>
<!--
  tv-tunnel launchd agent — starts Tailscale Funnel for the tickvault API
  port (3001, bearer-auth) on Mac boot. Installed by install-mac.sh into
  ~/Library/LaunchAgents/ so it runs under the logged-in user, not root.

  Security trim 2026-07-04: ONLY 3001 is funnelled. Prometheus 9090 /
  Alertmanager 9093 / Grafana 3000 are retired (CloudWatch-only migration);
  QuestDB 9000 is intentionally NO LONGER funnelled — it is an auth-less
  raw-SQL surface (local access only).

  The @TAILSCALE_BIN@ placeholder is substituted at install time because
  the Tailscale app path may vary between standard Mac App Store
  installs and brew cask installs.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tickvault.tunnel</string>

  <key>ProgramArguments</key>
  <array>
    <string>@TAILSCALE_BIN@</string>
    <string>funnel</string>
    <string>--bg</string>
    <string>3001</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>StandardOutPath</key>
  <string>/tmp/tickvault-tunnel.out.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/tickvault-tunnel.err.log</string>

  <key>ThrottleInterval</key>
  <integer>30</integer>
</dict>
</plist>
