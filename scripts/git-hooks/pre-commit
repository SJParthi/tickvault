#!/usr/bin/env bash
# =============================================================================
# dhan-live-trader — Pre-Commit Hook (Comprehensive)
# =============================================================================
# Runs before every commit. Blocks commit if any check fails.
# Calls .claude/hooks/ scanners for banned patterns, secrets, dedup/latency.
#
# Gates (< 5s total):
#   1. cargo fmt --check
#   2. Banned pattern scanner (.claude/hooks/banned-pattern-scanner.sh)
#   3. O(1) latency & dedup scanner (.claude/hooks/dedup-latency-scanner.sh)
#   4. Secret scanner (.claude/hooks/secret-scanner.sh)
#   5. Cargo.toml version pinning (no ^, ~, *, >=)
#   6. Typos check
#
# Commit message format is enforced in the commit-msg hook.
# Heavy gates (clippy, test, audit) run in the pre-push hook.
# Install: git config core.hooksPath scripts/git-hooks
# =============================================================================

set -uo pipefail

PROJECT_DIR="$(git rev-parse --show-toplevel 2>/dev/null)"
CLAUDE_HOOKS="$PROJECT_DIR/.claude/hooks"

# Check if any files are staged
RS_STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep '\.rs$' || true)
ALL_STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [ -z "$ALL_STAGED" ]; then
  exit 0
fi

FAILED=0

echo "╔══════════════════════════════════════════════╗" >&2
echo "║      PRE-COMMIT FAST GATE (6 Gates)          ║" >&2
echo "╚══════════════════════════════════════════════╝" >&2

# ─────────────────────────────────────────────
# GATE 1-3: Rust-specific gates (only if .rs files staged)
# ─────────────────────────────────────────────
if [ -n "$RS_STAGED" ]; then

  echo "  [1/6] cargo fmt --check..." >&2
  FMT_OUT=$(timeout 120 cargo fmt --all -- --check 2>&1)
  FMT_EXIT=$?
  if [ "$FMT_EXIT" -eq 124 ]; then
    echo "  FAIL: cargo fmt timed out (120s)" >&2
    FAILED=1
  elif [ "$FMT_EXIT" -ne 0 ]; then
    echo "  FAIL: cargo fmt check failed:" >&2
    echo "$FMT_OUT" | tail -20 >&2
    echo "  Run 'cargo fmt --all' to fix." >&2
    FAILED=1
  else
    echo "  PASS: cargo fmt" >&2
  fi

  # Gate 2: Banned pattern scanner
  echo "  [2/6] Banned pattern scan..." >&2
  if [ -x "$CLAUDE_HOOKS/banned-pattern-scanner.sh" ]; then
    SCAN_OUT=$(timeout 30 "$CLAUDE_HOOKS/banned-pattern-scanner.sh" "$PROJECT_DIR" "$RS_STAGED" 2>&1)
    SCAN_EXIT=$?
    if [ "$SCAN_EXIT" -eq 124 ]; then
      echo "  FAIL: Banned pattern scanner timed out (30s)" >&2
      FAILED=1
    elif [ "$SCAN_EXIT" -ne 0 ]; then
      echo "$SCAN_OUT" >&2
      FAILED=1
    else
      echo "  PASS: Banned pattern scan" >&2
    fi
  else
    echo "  SKIP: banned-pattern-scanner.sh not found" >&2
  fi

  # Gate 3: O(1) latency & dedup scanner
  echo "  [3/6] O(1) latency & dedup scan..." >&2
  if [ -x "$CLAUDE_HOOKS/dedup-latency-scanner.sh" ]; then
    DEDUP_OUT=$(timeout 30 "$CLAUDE_HOOKS/dedup-latency-scanner.sh" "$PROJECT_DIR" "$RS_STAGED" 2>&1)
    DEDUP_EXIT=$?
    if [ "$DEDUP_EXIT" -eq 124 ]; then
      echo "  FAIL: O(1) latency scanner timed out (30s)" >&2
      FAILED=1
    elif [ "$DEDUP_EXIT" -ne 0 ]; then
      echo "$DEDUP_OUT" >&2
      FAILED=1
    else
      echo "  PASS: O(1) latency & dedup scan" >&2
    fi
  else
    echo "  SKIP: dedup-latency-scanner.sh not found" >&2
  fi

else
  echo "  [1/6] No .rs files staged — skipping fmt" >&2
  echo "  [2-3/6] No .rs files staged — skipping Rust scanners" >&2
fi

# ─────────────────────────────────────────────
# GATE 4: Secret scanner (all staged files)
# ─────────────────────────────────────────────
echo "  [4/6] Secret scan..." >&2
if [ -x "$CLAUDE_HOOKS/secret-scanner.sh" ]; then
  SECRET_OUT=$(timeout 30 "$CLAUDE_HOOKS/secret-scanner.sh" "$PROJECT_DIR" "$ALL_STAGED" 2>&1)
  SECRET_EXIT=$?
  if [ "$SECRET_EXIT" -eq 124 ]; then
    echo "  FAIL: Secret scanner timed out (30s)" >&2
    FAILED=1
  elif [ "$SECRET_EXIT" -ne 0 ]; then
    echo "$SECRET_OUT" >&2
    FAILED=1
  else
    echo "  PASS: Secret scan" >&2
  fi
else
  echo "  SKIP: secret-scanner.sh not found" >&2
fi

# ─────────────────────────────────────────────
# GATE 5: Cargo.toml version pinning (no ^, ~, *, >=)
# ─────────────────────────────────────────────
TOML_STAGED=$(echo "$ALL_STAGED" | grep 'Cargo\.toml$' || true)
if [ -n "$TOML_STAGED" ]; then
  echo "  [5/6] Cargo.toml version pinning check..." >&2
  TOML_VIOLATIONS=0
  while IFS= read -r toml_file; do
    [ -z "$toml_file" ] && continue
    local_toml="$PROJECT_DIR/$toml_file"
    [ ! -f "$local_toml" ] && continue

    pin_matches=$(grep -n -E 'version\s*=\s*"[\^~*>]' "$local_toml" 2>/dev/null | grep -v '^[[:space:]]*#' || true)
    if [ -n "$pin_matches" ]; then
      echo "  FAIL: Unpinned versions in $toml_file:" >&2
      echo "$pin_matches" >&2
      TOML_VIOLATIONS=$((TOML_VIOLATIONS + 1))
    fi
  done <<< "$TOML_STAGED"

  if [ "$TOML_VIOLATIONS" -gt 0 ]; then
    echo "  All Cargo.toml dependencies must use exact versions. ^, ~, *, >= are BANNED." >&2
    FAILED=1
  else
    echo "  PASS: Cargo.toml versions pinned" >&2
  fi
else
  echo "  [5/6] No Cargo.toml staged — skipping version pin check" >&2
fi

# ─────────────────────────────────────────────
# GATE 6: Typos check
# ─────────────────────────────────────────────
echo "  [6/6] Typos check..." >&2
if command -v typos > /dev/null 2>&1; then
  TYPO_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep -E '\.(rs|toml|md|yml|yaml|sh)$' || true)
  if [ -n "$TYPO_FILES" ]; then
    TYPOS_OUT=""
    TYPOS_FAIL=0
    while IFS= read -r tf; do
      [ -z "$tf" ] && continue
      [ ! -f "$tf" ] && continue
      RESULT=$(timeout 10 typos "$tf" 2>&1 || true)
      if [ -n "$RESULT" ]; then
        TYPOS_OUT="${TYPOS_OUT}${RESULT}\n"
        TYPOS_FAIL=1
      fi
    done <<< "$TYPO_FILES"
    if [ "$TYPOS_FAIL" -ne 0 ]; then
      echo "  FAIL: Typos found:" >&2
      echo -e "$TYPOS_OUT" | head -20 >&2
      FAILED=1
    else
      echo "  PASS: No typos" >&2
    fi
  else
    echo "  SKIP: No checkable files staged" >&2
  fi
else
  echo "  SKIP: typos not installed" >&2
fi

# ─────────────────────────────────────────────
# FINAL VERDICT
# ─────────────────────────────────────────────
echo "" >&2
if [ "$FAILED" -ne 0 ]; then
  echo "╔══════════════════════════════════════════════╗" >&2
  echo "║  COMMIT BLOCKED — Fix violations above       ║" >&2
  echo "╚══════════════════════════════════════════════╝" >&2
  exit 1
fi

# Write state file for pre-push dedup optimization
HEAD_HASH=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
TEST_COUNT=$(grep -r '#\[test\]' crates/ --include='*.rs' 2>/dev/null | wc -l | tr -d ' ')
echo "$HEAD_HASH $(date +%s) $TEST_COUNT" > "$CLAUDE_HOOKS/.last-quality-pass"

echo "╔══════════════════════════════════════════════╗" >&2
echo "║  ALL 6 GATES PASSED — Commit allowed          ║" >&2
echo "╚══════════════════════════════════════════════╝" >&2
exit 0
