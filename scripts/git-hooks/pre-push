#!/usr/bin/env bash
# =============================================================================
# dhan-live-trader — Pre-Push Hook (Comprehensive — 11 Gates)
# =============================================================================
# Final safety net before code leaves the machine. Blocks push on failure.
# Calls .claude/hooks/ scanners for banned patterns, test count, data integrity,
# pub fn test coverage, and financial test guards.
#
# DEDUP: If pre-commit gate passed for same HEAD within 5 min,
# gates 1-5 are SKIPPED. Only push-only gates run.
#
# Gate order:
#   1. cargo fmt --check          [skippable if commit-verified]
#   2. cargo clippy -D warnings   [skippable if commit-verified]
#   3. cargo test (full workspace) [skippable if commit-verified]
#   4. Banned pattern scan (full)  [skippable if commit-verified]
#   5. Test count guard            [skippable if commit-verified]
#   6. cargo audit (CVEs + yanked)
#   7. cargo deny check (license + advisory)
#   8. Loom concurrency tests
#   9. Data integrity guard (price precision)
#  10. Pub fn test guard (every pub fn has a test)
#  11. Financial test guard (price/money fns have boundary tests)
#
# Install: git config core.hooksPath scripts/git-hooks
# =============================================================================

set -uo pipefail

PROJECT_DIR="$(git rev-parse --show-toplevel 2>/dev/null)"
CLAUDE_HOOKS="$PROJECT_DIR/.claude/hooks"

cd "$PROJECT_DIR" || { echo "  FAIL: Cannot cd to $PROJECT_DIR" >&2; exit 1; }

# Check if any .rs files exist
RS_EXISTS=$(find crates -name '*.rs' 2>/dev/null | head -1)
if [ -z "$RS_EXISTS" ]; then
  exit 0
fi

FAILED=0

# ─────────────────────────────────────────────
# Gate 0: Design-first wall (ALWAYS runs — never dedup-skipped)
# Implementation logic (crates/*/src/*.rs) requires an APPROVED extensive plan
# covering Design / Edge Cases / Failure Modes / Test Plan / Rollback /
# Observability before code is written. PASS on docs/CI/hooks/config/deps.
# Escape hatch: PLAN-EXEMPT in the commit body for genuinely trivial changes.
# ─────────────────────────────────────────────
echo "  [0/11] Design-first wall (plan-gate)..." >&2
if [ -x "$CLAUDE_HOOKS/plan-gate.sh" ]; then
  PLAN_OUT=$(timeout 30 "$CLAUDE_HOOKS/plan-gate.sh" "$PROJECT_DIR" 2>&1)
  PLAN_EXIT=$?
  echo "$PLAN_OUT" >&2
  if [ "$PLAN_EXIT" -ne 0 ]; then
    FAILED=1
  fi
else
  echo "  SKIP: plan-gate.sh not found" >&2
fi

# ─────────────────────────────────────────────
# DEDUP CHECK: Did pre-commit gate already pass for this HEAD?
# ─────────────────────────────────────────────
STATE_FILE="$CLAUDE_HOOKS/.last-quality-pass"
HEAD_CURRENT=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
HEAD_PARENT=$(git rev-parse HEAD~1 2>/dev/null || echo "unknown")
COMMIT_VERIFIED=false
AGE=0

if [ -f "$STATE_FILE" ]; then
  SAVED_HASH=$(awk '{print $1}' "$STATE_FILE")
  SAVED_TIME=$(awk '{print $2}' "$STATE_FILE")
  NOW=$(date +%s)
  AGE=$(( NOW - SAVED_TIME ))

  if { [ "$SAVED_HASH" = "$HEAD_CURRENT" ] || [ "$SAVED_HASH" = "$HEAD_PARENT" ]; } && [ "$AGE" -lt 300 ]; then
    COMMIT_VERIFIED=true
  fi
fi

if [ "$COMMIT_VERIFIED" = "true" ]; then
  echo "╔══════════════════════════════════════════════╗" >&2
  echo "║  PRE-PUSH (FAST — commit-verified ${AGE}s ago) ║" >&2
  echo "╚══════════════════════════════════════════════╝" >&2
  echo "  [1-5/11] SKIP: Already verified by pre-commit gate" >&2
else
  echo "╔══════════════════════════════════════════════╗" >&2
  echo "║       PRE-PUSH SAFETY NET (11 Gates)         ║" >&2
  echo "╚══════════════════════════════════════════════╝" >&2

  # Gate 1: cargo fmt
  echo "  [1/11] cargo fmt --check..." >&2
  FMT_OUT=$(timeout 120 cargo fmt --all -- --check 2>&1)
  FMT_EXIT=$?
  if [ "$FMT_EXIT" -eq 124 ]; then
    echo "  FAIL: cargo fmt timed out (120s)" >&2
    FAILED=1
  elif [ "$FMT_EXIT" -ne 0 ]; then
    echo "  FAIL: Code not formatted:" >&2
    echo "$FMT_OUT" | tail -10 >&2
    FAILED=1
  else
    echo "  PASS: cargo fmt" >&2
  fi

  # Gate 2: cargo clippy
  echo "  [2/11] cargo clippy..." >&2
  CLIPPY_OUT=$(timeout 240 cargo clippy --workspace --all-targets -- -D warnings 2>&1)
  CLIPPY_EXIT=$?
  if [ "$CLIPPY_EXIT" -eq 124 ]; then
    echo "  FAIL: cargo clippy timed out (240s)" >&2
    FAILED=1
  elif [ "$CLIPPY_EXIT" -ne 0 ]; then
    echo "  FAIL: clippy warnings found:" >&2
    echo "$CLIPPY_OUT" | tail -20 >&2
    FAILED=1
  else
    echo "  PASS: cargo clippy (zero warnings)" >&2
  fi

  # Gate 3: cargo test
  echo "  [3/11] cargo test..." >&2
  TEST_OUT=$(timeout 300 cargo test --workspace 2>&1)
  TEST_EXIT=$?
  if [ "$TEST_EXIT" -eq 124 ]; then
    echo "  FAIL: cargo test timed out (300s)" >&2
    FAILED=1
  elif [ "$TEST_EXIT" -ne 0 ]; then
    echo "  FAIL: cargo test failed:" >&2
    echo "$TEST_OUT" | tail -20 >&2
    FAILED=1
  else
    echo "  PASS: cargo test" >&2
  fi

  # Gate 4: Banned pattern scan (push-scoped)
  # 2026-07-16 gate-integrity fix (operator-approved): the scanner takes a
  # NEWLINE-separated file list ($2) — the old `tr '\n' ' '` form made it
  # scan ZERO files. Push-scoped here; full tree runs in ci.yml Repo Guards.
  echo "  [4/11] Banned pattern scan (push-scoped)..." >&2
  PUSH_BASE=$(git merge-base origin/main HEAD 2>/dev/null || true)
  if [ -z "$PUSH_BASE" ]; then
    # fail-closed (review r2 F1): a degraded clone (missing origin/main) must
    # never fall back to a full-tree scan — that re-creates the killed-hook
    # fail-open on exactly the clones where the push range cannot be proven.
    echo "  FAIL: cannot resolve push range (origin/main missing) — run: git fetch origin main" >&2
    FAILED=1
  else
    # fail-closed (final review B-MED): a git-diff failure (partial clone
    # offline, corrupt object) must never masquerade as "no changes" → PASS
    CHANGED_PUSH_ALL=$(git diff --name-only "$PUSH_BASE"..HEAD 2>/dev/null)
    DIFF_EXIT=$?
    CHANGED_RS=$(printf '%s\n' "$CHANGED_PUSH_ALL" | grep -E '^crates/.*\.rs$' || true)
    RS_COUNT=$(printf '%s\n' "$CHANGED_RS" | sed '/^$/d' | wc -l | tr -d ' ')
    if [ "$DIFF_EXIT" -ne 0 ]; then
      echo "  FAIL: git diff failed (exit $DIFF_EXIT) — cannot enumerate push range; refusing to skip scans" >&2
      FAILED=1
    elif [ "$RS_COUNT" -eq 0 ]; then
      echo "  PASS: Banned pattern scan (no .rs changes in push range; full tree scanned in CI)" >&2
    elif [ -x "$CLAUDE_HOOKS/banned-pattern-scanner.sh" ]; then
      BANNED_TIMEOUT=$(( 60 + RS_COUNT / 2 ))
      BANNED_OUT=$(timeout "$BANNED_TIMEOUT" "$CLAUDE_HOOKS/banned-pattern-scanner.sh" "$PROJECT_DIR" "$CHANGED_RS" 2>&1)
      BANNED_EXIT=$?
      if [ "$BANNED_EXIT" -eq 124 ]; then
        echo "  FAIL: Banned pattern scan timed out (${BANNED_TIMEOUT}s) — blocking push" >&2
        FAILED=1
      elif [ "$BANNED_EXIT" -ne 0 ]; then
        echo "$BANNED_OUT" | tail -20 >&2
        echo "  FAIL: Banned patterns in push range ($RS_COUNT .rs file(s) scanned)" >&2
        FAILED=1
      else
        echo "  PASS: Banned pattern scan ($RS_COUNT .rs file(s) in push range)" >&2
      fi
    else
      echo "  SKIP: Scanner not available" >&2
    fi
  fi

  # Gate 5: Test count guard
  echo "  [5/11] Test count guard..." >&2
  if [ -x "$CLAUDE_HOOKS/test-count-guard.sh" ]; then
    if ! timeout 30 "$CLAUDE_HOOKS/test-count-guard.sh" "$PROJECT_DIR" 2>&1; then
      FAILED=1
    fi
  else
    echo "  SKIP: test-count-guard.sh not found" >&2
  fi
fi

# ─────────────────────────────────────────────
# Gates 6-8: Push-only gates (always run)
# ─────────────────────────────────────────────

# Gate 6: cargo audit
echo "  [6/11] cargo audit (CVEs + yanked)..." >&2
if command -v cargo-audit > /dev/null 2>&1; then
  AUDIT_OUT=$(timeout 30 cargo audit --deny yanked 2>&1)
  AUDIT_EXIT=$?
  if [ "$AUDIT_EXIT" -eq 124 ]; then
    echo "  FAIL: cargo audit timed out (30s)" >&2
    FAILED=1
  elif echo "$AUDIT_OUT" | grep -q "couldn't fetch advisory database"; then
    echo "  SKIP: Cannot reach advisory database (network)" >&2
  elif [ "$AUDIT_EXIT" -ne 0 ]; then
    echo "  FAIL: cargo audit found issues:" >&2
    echo "$AUDIT_OUT" | tail -15 >&2
    FAILED=1
  else
    echo "  PASS: cargo audit" >&2
  fi
else
  echo "  SKIP: cargo-audit not installed" >&2
fi

# Gate 7: cargo deny
echo "  [7/11] cargo deny..." >&2
if command -v cargo-deny > /dev/null 2>&1; then
  DENY_OUTPUT=$(timeout 30 cargo deny check 2>&1)
  DENY_EXIT=$?
  if [ "$DENY_EXIT" -eq 124 ]; then
    echo "  FAIL: cargo deny timed out (30s)" >&2
    FAILED=1
  elif [ "$DENY_EXIT" -ne 0 ]; then
    if echo "$DENY_OUTPUT" | grep -qi 'failed to fetch\|network\|transport\|proxy\|connect\|FETCH_HEAD\|advisory-db\|No such file\|cannot change to'; then
      echo "  SKIP: cargo deny cannot reach advisory DB (network). CI will enforce." >&2
    else
      echo "  FAIL: cargo deny found issues" >&2
      FAILED=1
    fi
  else
    echo "  PASS: cargo deny" >&2
  fi
else
  echo "  SKIP: cargo-deny not installed" >&2
fi

# Gate 8: Loom concurrency tests
echo "  [8/11] Loom concurrency tests (hot-path crates)..." >&2
HOT_CRATES="core trading"
LOOM_FOUND=false
for crate in $HOT_CRATES; do
  # Run ONLY the dedicated loom test targets (tests/loom_*.rs), gated behind the
  # crate's `loom` Cargo feature. Using --features loom + per-target --test keeps
  # the loom model-checker scoped to loom code without (a) forcing --cfg loom onto
  # the whole dependency tree or (b) dragging the crate's full --lib unit suite in.
  LOOM_TARGET_FLAGS=""
  for f in "crates/$crate/tests/"loom_*.rs; do
    [ -e "$f" ] || continue
    t=$(basename "$f" .rs)
    LOOM_TARGET_FLAGS="$LOOM_TARGET_FLAGS --test $t"
  done
  if [ -n "$LOOM_TARGET_FLAGS" ]; then
    LOOM_FOUND=true
    echo "  Running loom tests for crates/$crate ($LOOM_TARGET_FLAGS)..." >&2
    # shellcheck disable=SC2086
    LOOM_OUT=$(timeout 300 cargo test -p "tickvault-$crate" --features loom $LOOM_TARGET_FLAGS 2>&1)
    LOOM_EXIT=$?
    if [ "$LOOM_EXIT" -eq 124 ]; then
      echo "  FAIL: Loom tests timed out (300s) for $crate" >&2
      FAILED=1
    elif [ "$LOOM_EXIT" -ne 0 ]; then
      echo "  FAIL: Loom tests failed for $crate:" >&2
      echo "$LOOM_OUT" | tail -20 >&2
      FAILED=1
    else
      echo "  PASS: Loom tests for $crate" >&2
    fi
  fi
done
if [ "$LOOM_FOUND" = "false" ]; then
  echo "  SKIP: No loom tests in hot-path crates yet" >&2
fi

# ─────────────────────────────────────────────
# Gates 9-11: Test coverage enforcement (always run)
# ─────────────────────────────────────────────

# Gate 9: Data integrity guard (full workspace scan)
echo "  [9/11] Data integrity guard (full workspace)..." >&2
if [ -x "$CLAUDE_HOOKS/data-integrity-guard.sh" ]; then
  DIG_OUT=$(timeout 60 "$CLAUDE_HOOKS/data-integrity-guard.sh" "$PROJECT_DIR" 2>&1)
  DIG_EXIT=$?
  if [ "$DIG_EXIT" -eq 124 ]; then
    echo "  FAIL: Data integrity guard timed out (60s)" >&2
    FAILED=1
  elif [ "$DIG_EXIT" -ne 0 ]; then
    echo "$DIG_OUT" >&2
    FAILED=1
  else
    echo "  PASS: Data integrity (no price corruption patterns)" >&2
  fi
else
  echo "  SKIP: data-integrity-guard.sh not found" >&2
fi

# Gate 10: Pub fn test guard (every public function has a test)
echo "  [10/11] Pub fn test guard (full workspace)..." >&2
if [ -x "$CLAUDE_HOOKS/pub-fn-test-guard.sh" ]; then
  PUBFN_OUT=$(timeout 120 "$CLAUDE_HOOKS/pub-fn-test-guard.sh" "$PROJECT_DIR" "all" 2>&1)
  PUBFN_EXIT=$?
  if [ "$PUBFN_EXIT" -eq 124 ]; then
    echo "  FAIL: Pub fn test guard timed out (120s)" >&2
    FAILED=1
  elif [ "$PUBFN_EXIT" -ne 0 ]; then
    echo "$PUBFN_OUT" >&2
    FAILED=1
  else
    echo "  PASS: All public functions have tests" >&2
  fi
else
  echo "  SKIP: pub-fn-test-guard.sh not found" >&2
fi

# Gate 11: Financial test guard (price/money fns have boundary tests)
echo "  [11/11] Financial test guard..." >&2
if [ -x "$CLAUDE_HOOKS/financial-test-guard.sh" ]; then
  FIN_OUT=$(timeout 120 "$CLAUDE_HOOKS/financial-test-guard.sh" "$PROJECT_DIR" 2>&1)
  FIN_EXIT=$?
  if [ "$FIN_EXIT" -eq 124 ]; then
    echo "  FAIL: Financial test guard timed out (120s)" >&2
    FAILED=1
  elif [ "$FIN_EXIT" -ne 0 ]; then
    echo "$FIN_OUT" >&2
    FAILED=1
  else
    echo "  PASS: Financial functions have adequate tests" >&2
  fi
else
  echo "  SKIP: financial-test-guard.sh not found" >&2
fi

# ─────────────────────────────────────────────
# FINAL VERDICT
# ─────────────────────────────────────────────
echo "" >&2
if [ "$FAILED" -ne 0 ]; then
  echo "╔══════════════════════════════════════════════╗" >&2
  echo "║  PUSH BLOCKED — Fix issues above             ║" >&2
  echo "╚══════════════════════════════════════════════╝" >&2
  exit 1
fi

# Update state file
TEST_COUNT=$(grep -r '#\[test\]' crates/ --include='*.rs' 2>/dev/null | wc -l | tr -d ' ')
echo "$HEAD_CURRENT $(date +%s) $TEST_COUNT" > "$CLAUDE_HOOKS/.last-quality-pass"

if [ "$COMMIT_VERIFIED" = "true" ]; then
  echo "╔══════════════════════════════════════════════╗" >&2
  echo "║  PUSH ALLOWED (fast path — 6 gates only)     ║" >&2
  echo "╚══════════════════════════════════════════════╝" >&2
else
  echo "╔══════════════════════════════════════════════╗" >&2
  echo "║  ALL 11 GATES PASSED — Push allowed           ║" >&2
  echo "╚══════════════════════════════════════════════╝" >&2
fi
exit 0
