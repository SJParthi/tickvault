#!/usr/bin/env bash
# =============================================================================
# dhan-live-trader — Pre-Push Hook
# =============================================================================
# Runs before every push. Blocks push if any check fails.
# Checks: compilation, tests, security audit.
# Heavier than pre-commit — ensures nothing broken reaches GitHub.
# Install: git config core.hooksPath scripts/git-hooks
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

echo "=== Pre-push checks ==="

# --- Stage 1: Compile ---
echo -n "  Compiling workspace... "
if cargo check --workspace > /dev/null 2>&1; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo ""
    echo "  Compilation failed. Fix errors before pushing."
    echo ""
    exit 1
fi

# --- Stage 2: Tests ---
echo -n "  Running tests... "
if cargo test --workspace > /dev/null 2>&1; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo ""
    echo "  Tests failed. Fix failing tests before pushing."
    echo ""
    exit 1
fi

# --- Stage 3: Security Audit (if cargo-audit is installed) ---
echo -n "  Security audit... "
if command -v cargo-audit > /dev/null 2>&1; then
    if cargo audit > /dev/null 2>&1; then
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${YELLOW}WARNINGS${NC} (check cargo audit output)"
    fi
else
    echo -e "${YELLOW}SKIPPED${NC} (cargo-audit not installed — run bootstrap.sh)"
fi

echo -e "=== All pre-push checks ${GREEN}PASSED${NC} ==="
