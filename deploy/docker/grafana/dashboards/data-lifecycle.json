  "uid": "tv-data-lifecycle",
  "title": "tickvault — Data Lifecycle",
  "tags": ["tickvault", "instruments", "candles", "persistence"],
  "timezone": "Asia/Kolkata",
  "refresh": "1m",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "text",
      "id": 100,
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## Data Lifecycle — instruments → ticks → candles → views\n\nInstrument universe builds daily from Dhan CSV (~157K rows parsed, F&O filter -> ~106K contracts). Live ticks stream through the 3-tier buffer to QuestDB. 18 materialized views aggregate into candles_{1s..1M}. 5-year SEBI retention. **Green = pipeline flowing; red = stalled upstream or QuestDB pressure**."
      }
    },
    {
      "type": "row",
      "id": 110,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "title": "Instrument universe",
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Total contracts",
      "description": "Derivative contracts in the instrument registry (composite index).",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "tv_instrument_registry_total_entries", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "none",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "color": "orange", "value": 10000 }, { "color": "green", "value": 100000 }] }
        }
      },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "F&O underlyings",
      "description": "Distinct underlyings currently subscribed to F&O depth (typically ~221).",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "tv_fno_universe_derivative_contracts_total", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "none",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red" }, { "color": "orange", "value": 100 }, { "color": "green", "value": 200 }] }
        }
      },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Last universe build",
      "description": "Seconds since last successful instrument universe build. Should be < 24h.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "time() - tv_instrument_universe_last_build_epoch_secs", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 86400 }, { "color": "red", "value": 172800 }] }
        }
      },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Cross-seg collisions",
      "description": "I-P1-11. Expected baseline is 2 (NIFTY/ABB + BANKNIFTY/ADANIENT). >5 = new ID reused.",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "tv_instrument_registry_cross_segment_collisions", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "none",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 5 }, { "color": "red", "value": 10 }] }
        }
      },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "row",
      "id": 120,
