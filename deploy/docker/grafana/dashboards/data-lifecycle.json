  "description": "Data lifecycle — instrument universe build, candle aggregation, persistence throughput, dedup filtering, materialized-view freshness. Runbook: .claude/rules/project/observability-architecture.md + .claude/rules/project/gap-enforcement.md",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
