      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(tv_depth_spilled_total[5m])", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "none",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 1 }] }
        }
