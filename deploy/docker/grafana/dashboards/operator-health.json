    {
      "id": 131,
      "type": "timeseries",
      "title": "Depth sequence holes / duplicates / rollbacks (PR #288)",
      "description": "tv_depth_sequence_*_total counters. Holes = lost packets. Duplicates = benign replay after reconnect. Rollbacks = server-side reconnect reset.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (segment,side) (rate(tv_depth_sequence_holes_total[5m]))",
          "legendFormat": "holes {{segment}} {{side}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (segment,side) (rate(tv_depth_sequence_duplicates_total[5m]))",
          "legendFormat": "duplicates {{segment}} {{side}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (segment,side) (rate(tv_depth_sequence_rollbacks_total[5m]))",
          "legendFormat": "rollbacks {{segment}} {{side}}",
          "refId": "C"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
