  "description": "Plan item F2 (2026-04-22) — 6-bucket movers taxonomy dashboard. One panel per bucket shows tv_movers_tracked_total; snapshot duration panels show compute_snapshot_v2 latency. Rich per-rank leaderboards land once the ILP writer (Phase C2) populates the top_movers QuestDB table.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "tv-market-movers",
  "title": "tickvault — Market Movers (6 buckets)",
  "tags": [
    "tickvault",
    "movers",
    "stocks",
    "options",
    "futures"
  ],
  "timezone": "Asia/Kolkata",
  "refresh": "10s",
  "schemaVersion": 39,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Instrument counts per bucket (tv_movers_tracked_total)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Indices",
      "description": "Live count of IDX_I instruments the tracker is currently ranking.",
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "tv_movers_tracked_total{bucket=\"indices\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "none",
          "decimals": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"colorMode": "background_solid", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Stocks",
