    {
      "type": "row",
      "title": "Snapshot compute latency (tv_movers_snapshot_duration_ms)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "compute_snapshot_v2 p95 latency (ms)",
      "description": "p95 wall time of MoversTrackerV2::compute_snapshot_v2. Budget: < 50ms for a 25k-instrument universe. If this climbs, the 6-bucket sort became expensive.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, rate(tv_movers_snapshot_duration_ms_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, rate(tv_movers_snapshot_duration_ms_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "ms",
          "decimals": 2
        }
      }
    },
    {
      "type": "timeseries",
      "title": "compute_snapshot_v2 rate (snapshots/min)",
      "description": "Recompute cadence. At 5s default cadence this should stay near 12 snapshots/min during market hours. 0 = tracker stalled.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(tv_movers_snapshot_duration_ms_count[1m]) * 60",
          "legendFormat": "snapshots/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "ops",
          "decimals": 1
        }
      }
    }
  ]
