    {
      "datasource": { "type": "postgres", "uid": "questdb" },
      "description": "Historical OHLCV candlestick chart from Dhan REST API. Pick Underlying → Instrument → Timeframe from dropdowns above. 1m candles aggregated via SAMPLE BY into selected timeframe. SMA 20 overlay.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "color": { "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "open" },
            "properties": [
              { "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": false } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "SMA 20" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#FF9800", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "volume" },
            "properties": [
              { "id": "unit", "value": "locale" },
              { "id": "custom.hideFrom", "value": { "legend": false, "tooltip": false, "viz": false } }
            ]
          }
        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 6 },
      "id": 11,
      "options": {
        "mode": 2,
        "candleStyle": "candles",
        "colorStrategy": "open-close",
        "colors": { "up": "green", "down": "red", "flat": "gray" },
        "includeAllFields": true
      },
      "title": "Historical — ${contract:text}  [${timeframe}]",
      "type": "candlestick",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "questdb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  ts AS time,\n  first(open) AS open,\n  max(high) AS high,\n  min(low) AS low,\n  last(close) AS close,\n  sum(volume) AS volume\nFROM historical_candles_1m\nWHERE security_id = ${contract}\n  AND segment = '${segment}'\n  AND ts >= '${__from:date:iso}'\n  AND ts < '${__to:date:iso}'\nSAMPLE BY ${timeframe}\nALIGN TO CALENDAR WITH OFFSET '05:30'\nORDER BY ts;",
          "refId": "OHLCV"
        },
        {
          "datasource": { "type": "postgres", "uid": "questdb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT time, avg(close) OVER (ORDER BY time ROWS BETWEEN 19 PRECEDING AND CURRENT ROW) AS \"SMA 20\"\nFROM (\n  SELECT\n    ts AS time,\n    last(close) AS close\n  FROM historical_candles_1m\n  WHERE security_id = ${contract}\n    AND segment = '${segment}'\n    AND ts >= '${__from:date:iso}'\n    AND ts < '${__to:date:iso}'\n  SAMPLE BY ${timeframe}\n  ALIGN TO CALENDAR WITH OFFSET '05:30'\n  ORDER BY ts\n);",
          "refId": "SMA",
          "hide": false
        }
      ]
    },
