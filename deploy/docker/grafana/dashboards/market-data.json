      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "questdb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  segment,\n  security_id,\n  ltp,\n  open,\n  high,\n  low,\n  close,\n  volume,\n  oi,\n  avg_price,\n  last_trade_qty,\n  total_buy_qty,\n  total_sell_qty,\n  to_str(ts, 'yyyy-MM-dd HH:mm:ss.SSS') AS exchange_time,\n  to_str(received_at, 'yyyy-MM-dd HH:mm:ss.SSS') AS received_at\nFROM ticks\nWHERE ts >= dateadd('s', 19800, '${__from:date:iso}')\n  AND ts < dateadd('s', 19800, '${__to:date:iso}')\nORDER BY ts DESC\nLIMIT 200;",
          "refId": "A"
        }
      ]
