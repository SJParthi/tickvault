{
  "__inputs": [
    {
      "name": "DS_CLOUDWATCH",
      "label": "CloudWatch (Tickvault/Prod)",
      "description": "AWS CloudWatch datasource (Assume Role, region ap-south-1). Read-only.",
      "type": "datasource",
      "pluginId": "cloudwatch",
      "pluginName": "CloudWatch"
    },
    {
      "name": "DS_QUESTDB",
      "label": "QuestDB (PostgreSQL via PDC)",
      "description": "QuestDB over the Private Datasource Connect PostgreSQL datasource (localhost:8812). SELECT-only by convention.",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "cloudwatch", "name": "CloudWatch", "version": "1.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["tickvault", "operator", "mobile"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "Asia/Kolkata",
  "title": "TickVault — Operator (mobile)",
  "uid": "tv-operator-mobile",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Overall health score (≥ 0.95 = healthy)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.8 },
            { "color": "green", "value": 0.95 }
          ] }
        }, "overrides": []
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_realtime_guarantee_score", "statistic": "Average", "dimensions": { "host": "*" }, "region": "ap-south-1", "metricQueryType": 0, "metricEditorMode": 0, "matchExact": false }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Market feed (0 = LIVE)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": { "0": { "text": "LIVE ✅", "color": "green", "index": 0 } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
      }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_websocket_pool_all_dead", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Order feed (≥ 1 = up)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_order_update_ws_active", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "QuestDB down (sec, 0 = good)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 30 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_questdb_disconnected_seconds", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false } ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Clock skew (sec, < 2 = good)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 2 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_clock_skew_seconds", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false } ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Token life left (> 4h = good)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 14400 }, { "color": "green", "value": 28800 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_token_remaining_seconds", "statistic": "Minimum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false } ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Feed last-tick age s (low = good)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_feed_last_tick_age_seconds", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false } ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Ticks dropped (0 = good)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_spill_dropped_total", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false },
        { "refId": "B", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_dlq_ticks_total", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Orders rejected (0 = good)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_orders_rejected_total", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false } ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Candles sealed (should keep rising during market hours)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_aggregator_seals_emitted_total", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false } ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Health score + WS failed connections over time",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_realtime_guarantee_score", "statistic": "Average", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false },
        { "refId": "B", "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" }, "namespace": "Tickvault/Prod", "metricName": "tv_websocket_failed_connections_count", "statistic": "Maximum", "dimensions": { "host": "*" }, "region": "ap-south-1", "matchExact": false }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Total ticks captured (today's partitions)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 15 },
      "datasource": { "type": "postgres", "uid": "${DS_QUESTDB}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [ { "refId": "A", "datasource": { "type": "postgres", "uid": "${DS_QUESTDB}" }, "format": "table", "rawQuery": true, "rawSql": "SELECT count() AS total FROM ticks" } ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Ticks per minute (live capture rate)",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 15 },
      "datasource": { "type": "postgres", "uid": "${DS_QUESTDB}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "datasource": { "type": "postgres", "uid": "${DS_QUESTDB}" }, "format": "time_series", "rawQuery": true, "rawSql": "SELECT ts AS \"time\", count() AS ticks FROM ticks WHERE $__timeFilter(ts) SAMPLE BY 1m" } ]
    },
    {
      "id": 14,
      "type": "table",
      "title": "Latest 50 ticks",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "postgres", "uid": "${DS_QUESTDB}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [ { "refId": "A", "datasource": { "type": "postgres", "uid": "${DS_QUESTDB}" }, "format": "table", "rawQuery": true, "rawSql": "SELECT ts, segment, security_id, ltp, volume, total_buy_qty, total_sell_qty FROM ticks ORDER BY ts DESC LIMIT 50" } ]
    }
  ]
}
