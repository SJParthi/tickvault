{
  "agent": { "metrics_collection_interval": 60 },
  "metrics": {
    "metrics_collected": {
      "disk": { "measurement": ["used_percent"], "resources": ["/"] },
      "mem":  { "measurement": ["mem_used_percent"] },
      "cpu":  { "measurement": ["cpu_usage_active"] }
    },
    "append_dimensions": { "InstanceId": "${aws:InstanceId}" }
  },
  "logs": {
    "metrics_collected": {
      "prometheus": {
        "prometheus_config_path": "/opt/aws/amazon-cloudwatch-agent/etc/prometheus.yaml",
        "log_group_name": "/tickvault/prod/metrics",
        "emf_processor": {
          "metric_namespace": "Tickvault/Prod",
          "metric_declaration_dedup": true,
          "metric_declaration": [
            {
              "source_labels": ["host"],
              "label_matcher": "^tickvault-prod$",
              "dimensions": [["host"]],
              "metric_selectors": ["^(tv_websocket_pool_all_dead|tv_websocket_failed_connections_count|tv_order_update_ws_active|tv_questdb_disconnected_seconds|tv_tick_gap_instruments_silent|tv_token_remaining_seconds|tv_spill_dropped_total|tv_dlq_ticks_total|tv_ticks_dropped_total|tv_aggregator_seals_emitted_total|tv_aggregator_close_pct_nonzero_total|tv_orders_rejected_total|tv_realtime_guarantee_score|tv_boot_completed|tv_clock_skew_seconds|tv_ws_frame_dropped_no_wal_total|tv_ws_reconnect_gap_seconds_total|tv_disk_watcher_respawn_total|tv_late_tick_after_boundary_total|tv_process_rss_bytes|tv_subsystem_memory_estimated_bytes|tv_dhan_exchange_lag_p99_seconds|tv_dhan_lag_samples_excluded_total)$"]
            },
            {
              "source_labels": ["host"],
              "label_matcher": "^tickvault-prod$",
              "dimensions": [["host", "feed"]],
              "metric_selectors": ["^tv_boundary_catchup_total$"]
            }
          ]
        }
      }
    },
    "logs_collected": {
      "files": {
        "collect_list": [
          { "file_path": "/opt/tickvault/data/logs/errors.jsonl*", "log_group_name": "/tickvault/prod/app", "log_stream_name": "{instance_id}/errors-jsonl", "timezone": "UTC" },
          { "file_path": "/opt/tickvault/data/logs/app.*", "log_group_name": "/tickvault/prod/app", "log_stream_name": "{instance_id}/app", "timezone": "UTC" }
        ]
      }
    }
  }
}
