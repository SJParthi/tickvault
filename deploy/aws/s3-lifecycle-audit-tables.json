{
  "_comment": "Wave 2 Item 9.4 — S3 lifecycle policy for the 6 audit tables. Apply via: aws s3api put-bucket-lifecycle-configuration --bucket tickvault-audit --lifecycle-configuration file://deploy/aws/s3-lifecycle-audit-tables.json. Cost target: under 333 INR per month for up to 500 GB across all 6 tables (per .claude/rules/project/aws-budget.md). Retention: 90d hot in QuestDB, 90 to 365 days S3 Intelligent-Tiering, 365 days plus Glacier Deep Archive. order_audit honors SEBI 5y minimum (1825 days).",
  "Rules": [
    {
      "ID": "phase2-audit-lifecycle",
      "Status": "Enabled",
      "Filter": { "Prefix": "phase2_audit/" },
      "Transitions": [
        { "Days": 0,   "StorageClass": "INTELLIGENT_TIERING" },
        { "Days": 90,  "StorageClass": "GLACIER_IR" },
        { "Days": 365, "StorageClass": "DEEP_ARCHIVE" }
      ],
      "Expiration": { "Days": 1825 }
    },
    {
      "ID": "depth-rebalance-audit-lifecycle",
      "Status": "Enabled",
      "Filter": { "Prefix": "depth_rebalance_audit/" },
