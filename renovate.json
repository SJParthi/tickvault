{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Asia/Kolkata",
  "schedule": ["after 3:45pm every weekday"],
  "labels": ["dependencies"],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Group all Cargo workspace dependencies into single PR",
      "matchManagers": ["cargo"],
      "groupName": "Cargo dependencies",
      "groupSlug": "cargo-all",
      "labels": ["dependencies", "rust"],
      "automerge": true
    },
    {
      "description": "GitHub Actions updates grouped — auto-merge after CI",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions-all",
      "labels": ["ci", "dependencies"],
      "automerge": true
    },
    {
      "description": "Docker Compose image updates grouped",
      "matchManagers": ["docker-compose"],
      "groupName": "Docker images",
      "groupSlug": "docker-compose-all",
      "labels": ["dependencies", "docker"],
      "automerge": true
    },
    {
      "description": "Security vulnerability fixes bypass schedule and merge immediately",
      "matchCategories": ["rust"],
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "1 day",
      "automerge": true,
      "schedule": ["at any time"]
    },
    {
      "description": "Major version bumps require manual review — do NOT automerge",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "breaking"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"],
    "automerge": true,
    "schedule": ["at any time"]
  }
}
