# =============================================================================
# dhan-live-trader — .gitignore
# =============================================================================

# ---- Rust ----
/target/
**/*.rs.bk

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- Environment (BANNED — but gitignore for safety) ----
.env
.env.*
*.env

# ---- Secrets / Credentials (NEVER commit) ----
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account*.json
*-secret*.json

# ---- Config overrides (personal machine-specific, not committed) ----
config/local-overrides.toml
.claude/settings.local.json

# ---- Docker volumes (if mounted locally) ----
docker-data/

# ---- Logs ----
*.log
logs/

# ---- Coverage reports ----
tarpaulin-report.html
lcov.info
coverage/
target/llvm-cov/

# ---- Benchmark artifacts ----
criterion/

# ---- Fuzz artifacts ----
fuzz/artifacts/
fuzz/corpus/
fuzz/target/

# ---- Quality gate state files (local machine state) ----
.claude/hooks/.last-quality-pass
.claude/hooks/.test-count-baseline
.claude/hooks/.coverage-baseline
.claude/hooks/.untested-pubfn-baseline
.claude/hooks/.financial-test-baseline
.claude/hooks/.last-session-check
quality/.binary-size-baseline

# ---- Auto-save watchdog (runtime state) ----
.claude/hooks/.watchdog.pid
.claude/hooks/.watchdog.log

# ---- Auto-save remote watchdog (runtime state) ----
.claude/hooks/.remote-watchdog.pid
.claude/hooks/.remote-watchdog.log
.claude/hooks/.auto-save-index
.claude/hooks/.conflict-warning
.claude/hooks/.collision-detected
.claude/hooks/.session-network.log
.claude/hooks/.push-in-progress

# ---- Grill review state (runtime state) ----
.claude/hooks/.last-grill-pass

# ---- Integration sync (runtime state) ----
.claude/.integration-worktree/
.claude/hooks/.integration-sync.lock/
.claude/hooks/.integration-sync.log

# ---- Instrument data cache (large CSVs) ----
data/
data/instrument-cache/

# ---- Database artifacts (stray files outside docker-data/) ----
*.sqlite
*.db
*.rdb

# ---- Profiling artifacts ----
*.profraw
*.profdata

# ---- PID files ----
*.pid

# ---- Temporary files ----
*.tmp
*.bak
mutants.out/
mutants.out.old/
target/llvm-cov-target/
.claude/worktrees/
target2/
