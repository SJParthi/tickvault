# =============================================================================
# dhan-live-trader — Local Development Overrides (EXAMPLE)
# =============================================================================
# Copy this to config/local.toml for running OUTSIDE Docker (cargo run on host).
# Docker hostnames → localhost. JSON logs → pretty logs.
#
#   cp config/local.toml.example config/local.toml
#
# local.toml is git-ignored. Modify your copy freely.
# =============================================================================

[questdb]
host = "localhost"

[valkey]
host = "localhost"

[prometheus]
host = "localhost"

[logging]
format = "pretty"
