{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "high",
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "85",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "600000"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Bash(cargo check *)",
      "Bash(cargo check)",
      "Bash(cargo test *)",
      "Bash(cargo test)",
      "Bash(cargo fmt *)",
      "Bash(cargo fmt)",
      "Bash(cargo clippy *)",
      "Bash(cargo clippy)",
      "Bash(cargo doc *)",
      "Bash(cargo build *)",
      "Bash(cargo build)",
      "Bash(cargo bench *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(git tag *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-remote *)",
      "Bash(git show *)",
      "Bash(git rev-list *)",
      "Bash(docker compose *)",
      "Bash(docker build *)",
      "Bash(docker ps *)",
      "Bash(docker ps)",
      "Bash(docker logs *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(rustfmt *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(docker exec *)",
      "Bash(chmod *)",
      "Bash(make *)",
      "Bash(make)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(bash *)"
    ],
    "deny": [
      "Bash(cargo update *)",
      "Bash(cargo update)",
      "Bash(rm -rf *)",
      "Bash(rm -r -f *)",
      "Bash(rm -fr *)",
      "Bash(rm -Rf *)",
      "Bash(sudo *)",
      "Bash(brew *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git checkout -- .)",
      "Bash(git checkout .)",
      "Bash(git stash drop *)",
      "Bash(git stash drop)",
      "Bash(git stash clear)",
      "Bash(gh repo delete *)",
      "Bash(gh api -X DELETE *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-env-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-tool-dispatch.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-push-sync.sh",
            "timeout": 10,
            "statusMessage": "Syncing to integration branch..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-grill-reminder.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-auto-verify.sh",
            "timeout": 60,
            "statusMessage": "Auto-verifying changed Rust files..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|authentication_failed|billing_error|invalid_request|server_error|max_output_tokens",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-failure-alert.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-sanity.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear|logout|prompt_input_exit|other",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end-save.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"SUBAGENT SPAWNED: $(cat | jq -r '.agent_type // .subagent_type // \"unknown\"')\" >&2"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"SUBAGENT COMPLETED\" >&2"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PRESERVE: (1) modified files list (2) test/build results (3) phase progress (4) unresolved errors (5) three principles'"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compact-recovery.sh",
            "timeout": 10,
            "statusMessage": "Recovering context after compaction..."
          }
        ]
      }
    ]
  }
}
