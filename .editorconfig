# =============================================================================
# dhan-live-trader — EditorConfig
# =============================================================================
# Universal editor config — works in IntelliJ, VS Code, vim, any editor.
# Ensures consistent formatting across all editors and contributors.
# https://editorconfig.org
# =============================================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.rs]
indent_size = 4
max_line_length = 100

[*.{toml,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{http,rest}]
indent_size = 2

[Makefile]
indent_style = tab

[Dockerfile]
indent_size = 4
